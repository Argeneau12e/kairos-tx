[187.152413, "o", "\r\n╔════════════════════════════════════════╗\r\n║           Run Complete                 ║\r\n╚════════════════════════════════════════╝\r\n\u001b[42X\r\nTotal bundles:  10\u001b[24X\r\nFinalized:      9\u001b[25X\r\nFailed:         0\u001b[25X\r\nSuccess rate:   90.0%\u001b[21X\r\n\u001b[42X\r\nNetwork Summary:\u001b[26X\r\n  Avg p→c delta: 2671ms\u001b[19X\r\n  p→c range:     2152ms – 3868ms\u001b[10X\r\n  Tip P75 range: 2376 – 10000 lam\u001b[9X\r\n  Tip volatility: 4.2x\u001b[20X\r\n"]
